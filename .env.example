# ─────────────────────────────────────────────────────────────────────────────
# Root AI — Environment Variables Template (free-tier / open-source only)
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# All paid / commercial API keys have been removed — this stack is 100% free.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
ROOT_AI_DISCORD_TOKEN=your-discord-bot-token-here

# Optional alternate token env name (ROOT_AI_DISCORD_TOKEN takes precedence)
# DISCORD_TOKEN=

# Command prefix for legacy prefix commands (default: .)
BOT_PREFIX=.

# Your Discord server (guild) ID — required for instant slash command sync
DISCORD_GUILD_ID=your-guild-id-here

# Your Discord user ID — used for owner-only commands and @mention alerts
BOT_OWNER_ID=your-discord-user-id

# Your Discord username (lowercase) — used to gate bot access to the owner only
BOT_OWNER_USERNAME=your-discord-username

# ── LLM / Ollama (local, free) ────────────────────────────────────────────────
# Ollama API endpoint — default points to local instance
LOCAL_LLM_URL=http://localhost:11434/v1

# Model to use — must be pulled on your Ollama instance first (ollama pull <model>)
LOCAL_MODEL_NAME=llama3.1

# ── SSH / Parrot OS ───────────────────────────────────────────────────────────
# IP or hostname of your Parrot OS machine (Raspberry Pi, VM, WSL, etc.)
PARROT_HOST=127.0.0.1

# SSH credentials for Parrot OS
PARROT_USER=your-parrot-username
PARROT_PASS=your-parrot-password

# CIDR subnet your C2 implants report from (used by Phase 3 C2 dashboard)
C2_SUBNET_CIDR=192.168.1.0/24

# ── Twitch (free — client credentials, no subscription needed) ────────────────
# Register your app at https://dev.twitch.tv/console/apps to get these
ROOT_AI_TWITCH_CLIENT_ID=your-twitch-client-id
ROOT_AI_TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Your Twitch channel username (lowercase)
TWITCH_BROADCASTER_LOGIN=your-twitch-username

# ── Discord channel IDs ───────────────────────────────────────────────────────
# Channel where Twitch live alerts are posted
TWITCH_NOTIFY_CHANNEL_ID=your-twitch-notify-channel-id

# Channel where HTB/THM streak-danger alerts are posted (Phase sec_monitor cog)
SEC_MONITOR_CHANNEL_ID=your-sec-monitor-channel-id

# Channel where Phase 5 Watchdog new-asset alerts are posted
WATCHDOG_CHANNEL_ID=your-watchdog-alert-channel-id

# ── Shodan (free tier — api.host() only, no query credits) ──────────────────
# Generate at: https://account.shodan.io → API Keys
# Leave empty to disable Shodan intel in /recon and watchdog.
SHODAN_API_KEY=

# ── NVD — National Vulnerability Database (free) ──────────────────────────────
# Used by Phase 7 CVE enrichment in /recon, /autopwn, and watchdog alerts.
# Without a key: 5 req / 30 s (6.5 s sleep between CVE lookups).
# With a key:   50 req / 30 s (0.6 s sleep) — much faster enrichment.
# Register free (email only, instant): https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── HackTheBox (free tier) ────────────────────────────────────────────────────
# Generate at: https://app.hackthebox.com/profile/settings → App Tokens
# Leave empty to disable HTB streak monitoring
HTB_API_TOKEN=

# Your HTB numeric user ID (visible in your profile URL)
HTB_USER_ID=your-htb-user-id

# ── GitHub PAT (optional — for private repo auditing only) ───────────────────
# Needed only if you want /audit_repo to clone private GitHub repositories.
# Generate a fine-grained PAT with repo read-only scope.
# Leave empty for public repos (no authentication needed).
# This value is NEVER logged or shown in Discord output.
GITHUB_PAT=

# ── Phase 5 Watchdog ─────────────────────────────────────────────────────────
# Local path for SQLite baseline database (created automatically)
WATCHDOG_DB_PATH=data/watchdog.db

# How often the background loop rescans all targets (hours, default 6)
WATCHDOG_INTERVAL_HOURS=6

# ─────────────────────────────────────────────────────────────────────────────
# Tools required on Parrot OS (all free / open-source):
#   nmap         — sudo apt install nmap
#   subfinder    — go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest
#   assetfinder  — go install github.com/tomnomnom/assetfinder@latest
#   git          — sudo apt install git
# ─────────────────────────────────────────────────────────────────────────────
