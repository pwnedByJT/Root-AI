# =============================================================================
# Root AI — .gitignore
# =============================================================================

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
# Allow a sanitised template if you ever add one:
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Type checking / linting caches
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover

# ── IDEs & Editors ────────────────────────────────────────────────────────────
# VS Code personal workspace settings (extensions.json can be committed if desired)
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ── OS Artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & Temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig

# ── SSH / asyncssh ────────────────────────────────────────────────────────────
known_hosts
